generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tugas {
  id         Int      @id @default(autoincrement())
  judul      String
  selesai    Boolean  @default(false)
  dibuatPada DateTime @default(now())
}

model User {
  id       Int    @id @default(autoincrement())
  nama     String
  email    String @unique
  password String
}
